# Postgres connection string. On Railway, add a Postgres plugin to the
# project and it auto-injects this — no need to set it manually there.
DATABASE_URL=postgres://yoga_app:yoga_dev_pw@localhost:5432/yoga_ai_platform

# Long random string in production — dev falls back to an insecure default.
JWT_SECRET=change-me

# Railway injects this automatically; only needed for local runs.
PORT=4000
